# 开发环境配置
PORT=3000
# 监听地址（0.0.0.0 表示监听所有网卡，127.0.0.1 仅本地访问）
LISTEN_HOST=0.0.0.0
# 主机地址（仅用于开发环境日志输出）
HOST=10.4.45.192
# CORS 允许的源（生产环境必须配置，多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# 数据库类型
DB_TYPE=mysql
# 数据库主机
DB_HOST=localhost
# 数据库端口
DB_PORT=3306
# 数据库用户名
DB_USERNAME=root
# 数据库密码
DB_PASSWORD=
# 数据库名称
DB_DATABASE=personal-blog
# 是否自动同步数据库结构 （生产环境建议关闭）
DB_SYNCHRONIZE=true
# 是否在终端打印数据库日志
DB_LOGGING=false

# 邮箱类型
EMAIL_SERVICE=qq
# SMTP主机地址
EMAIL_HOST=smtp.qq.com
# SMTP端口号
EMAIL_PORT=465
# 发送邮件的邮箱账号
EMAIL_USER=3110869503@qq.com
# 发送邮件的邮箱密钥
EMAIL_PASS=xxxxxxx
# 发送邮件的邮箱显示名称
EMAIL_FROM=xxx<xxxxxxx@qq.com>

# 缓存存储类型：memory（内存缓存）或 redis（Redis缓存），如果使用memory下面可忽略
CACHE_STORE=memory
# Redis 主机地址
REDIS_HOST=127.0.0.1
# Redis 端口号
REDIS_PORT=6379
# Redis 密码
REDIS_PASSWORD=
# Redis 数据库索引
REDIS_DB=1

# Access Token 密钥
JWT_ACCESS_SECRET=yee-blog-access-secret-dev-2024
# Access Token 过期时间
JWT_ACCESS_EXPIRES_IN=30m
# Refresh Token 密钥
JWT_REFRESH_SECRET=yee-blog-refresh-secret-dev-2024
# Refresh Token 过期时间
JWT_REFRESH_EXPIRES_IN=7d

# 应用URL（用于本地存储生成访问URL，这个只是开发环境用，生产环境需要配置为S3_ENDPOINT、S3_PUBLIC_URL）
APP_URL=http://localhost:3000
# 存储驱动：local（本地）或 s3（S3/MinIO/OSS 兼容，使用对象存储就用 s3）
STORAGE_DRIVER=local
# 允许上传的目录，多个用逗号分隔
STORAGE_ALLOWED_FOLDERS=avatars,topics,general,covers,instation
# 最大文件大小（字节，默认3MB）
MAX_FILE_SIZE=3145728
# S3 存储桶名称（必填）
S3_BUCKET_NAME=my-bucket
# AWS 区域 新加坡
AWS_REGION=ap-southeast-1
# AWS 访问密钥（必填）
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# 后端内网访问
S3_ENDPOINT=object-storage.objectstorage-system.svc.cluster.local
# 前端公网访问 （如果没有CDN、反向代理等需求，可以和S3_ENDPOINT一样，否则配置 CDN 域名）
S3_PUBLIC_URL=objectstorageapi.ap-southeast-1.clawcloudrun.com

# 混元 AI 配置
# 混元 AI 密钥
HUNYUAN_SECRET_ID=
HUNYUAN_SECRET_KEY=
# 混元 AI 区域
HUNYUAN_REGION=ap-singapore
# 混元 AI 模型
HUNYUAN_MODEL=hunyuan-turbo
# 混元 AI 温度
HUNYUAN_TEMPERATURE=0.8

# Logging
APP_NAME=personal-blog-server
# 日志级别
LOG_LEVEL=debug
# 日志目录
LOG_DIR=logs
# 是否开启生成文件日志
LOG_FILE_ENABLED=true
# 是否在终端打印 JSON 格式日志
LOG_CONSOLE_JSON=false
# 日志文件最大大小（MB）
LOG_FILE_MAX_SIZE_MB=20
# 日志文件最大数量
LOG_FILE_MAX_FILES=14
